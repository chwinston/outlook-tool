# Microsoft Graph API credentials (required for Mac/Linux only)
# Windows uses Outlook COM automation directly — no credentials needed.
#
# Option 1: Use the default Microsoft Office public client ID (no registration needed)
#   Leave these blank — the tool uses device code auth automatically.
#
# Option 2: Register your own Azure AD app for tighter tenant control
#   See README.md for full setup instructions.
KPI_GRAPH_CLIENT_ID=
KPI_GRAPH_TENANT_ID=
